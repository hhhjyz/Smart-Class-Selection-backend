# 服务自身
SERVICE_NAME=course-selection
SERVICE_PORT=8003
LOG_LEVEL=INFO
MODE=api

# 数据库
PG_DSN=postgres://cs_user:cs_pwd@course-selection-pg:5432/course_selection
PG_POOL_MIN=4
PG_POOL_MAX=32

# Redis
REDIS_URL=redis://course-selection-redis:6379/0

# RabbitMQ
RMQ_URL=amqp://stss:stss@rabbitmq:5672/
RMQ_EXCHANGE_ENROLLMENT=enrollment.events

# 上游 A 组（基础信息，前缀 /api/v1）：身份 + 开课。真实契约见 A 组《api 设计》。
INFO_SERVICE_BASE_URL=http://info-service:8000
INFO_USER_PATH=/api/v1/users/{id}
INFO_OFFERINGS_PATH=/api/v1/offerings
INFO_OFFERING_DETAIL_PATH=/api/v1/offerings/{id}
INFO_SERVICE_TIMEOUT_MS=2000
# 服务间令牌：A 组 POST /api/v1/auth/sys/login（client_id/secret）签发后填这里
INFO_SERVICE_TOKEN=

# 鉴权（网关透传的 header 名）
JWT_USER_HEADER=X-User-ID
JWT_ROLE_HEADER=X-User-Role
REQUEST_ID_HEADER=X-Request-ID

# LLM
LLM_BASE_URL=
LLM_API_KEY=
LLM_CHAT_MODEL=gpt-4o-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_TIMEOUT_MS=60000

# 限流（运行期可被 /admin/throttle 热更新）
WAITROOM_TICK_MS=200
WAITROOM_CAP_PER_TICK=50
PER_USER_RPS=5
